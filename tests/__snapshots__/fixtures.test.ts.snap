  onchange: () => void;

  /**
   * Form submission with value
   */
  onsubmit: (detail: { value: string }) => void;
};

export default class RunesCallbackAnnotated extends SvelteComponentTyped<
  RunesCallbackAnnotatedProps,
  Record<string, any>,
  Record<string, never>
> {}
"
